menuconfig NTURT_SYS
	bool "Basic system support"
	depends on NTURT
	select REBOOT
	imply POWEROFF

if NTURT_SYS

rsource "fs/Kconfig"
rsource "rtc/Kconfig"

module = NTURT_SYS
module-str = Basic System
source "subsys/logging/Kconfig.template.log_config"

config NTURT_SYS_INIT_PRIORITY
	int "Init priority"
	default 0
	help
	  Basic system initialization priority.

config NTURT_WORKQUEUE_STACK_SIZE
	int "Workqueue thread stack size"
	default 8192
	help
	  Stack size for the workqueue thread.

config NTURT_WORKQUEUE_THREAD_PRIORITY
	int "Workqueue thread priority"
	default 5
	help
	  Priority for the workqueue thread.

DT_CHOSEN_NTURT_BUZZER := nturt,buzzer
config NTURT_SYS_REBOOT_SOUND
	bool "Reboot sound"
	depends on $(dt_chosen_enabled,$(DT_CHOSEN_NTURT_BUZZER))
	default y
	select GPIO

config NTURT_SHELL
	bool "Shell support"
	select SHELL

if NTURT_SHELL

DT_CHOSEN_ZEPHYR_CONSOLE := zephyr,console
DT_CHOSEN_ZEPHYR_SHELL_UART := zephyr,shell-uart
config LOG_SHELL_DIFFERENT_BACKEND
	bool
	depends on $(dt_chosen_enabled,$(DT_CHOSEN_ZEPHYR_CONSOLE))
	depends on $(dt_chosen_enabled,$(DT_CHOSEN_ZEPHYR_SHELL_UART))
	depends on "$(dt_chosen_path,$(DT_CHOSEN_ZEPHYR_CONSOLE))" != \
		"$(dt_chosen_path,$(DT_CHOSEN_ZEPHYR_SHELL_UART))"
	default y
	help
	  Log default to use shell as the backend if both console and shell use
	  serial as the backend. This option makes the log output to correct serial
	  port if the console and shell use different serial ports.

if LOG_SHELL_DIFFERENT_BACKEND

config LOG_BACKEND_UART
	default y
config SHELL_LOG_BACKEND
	default n

endif # LOG_SHELL_DIFFERENT_BACKEND

config LOG_CMDS
	default y
config THREAD_RUNTIME_STATS
	default y

endif # NTURT_SHELL

endif # NTURT_SYS
